{
  "manifest_version": 3,
  "name": "拓元搶票輔助",
  "version": "1.4",
  "description": "專為 Tixcraft 打造的搶票輔助擴充功能，支援多組關鍵字自動選區、防彈窗卡死、自動提交驗證碼。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://tixcraft.com/*", "*://*.tixcraft.com/*"],
      "js": ["anti_alert.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://tixcraft.com/*", "*://*.tixcraft.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
